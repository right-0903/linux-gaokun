From 8173c002c85f04382a0a60dfdd478307d2a81b2f Mon Sep 17 00:00:00 2001
From: Pengyu Luo <mitltlatltl@gmail.com>
Date: Sat, 18 Apr 2026 16:09:02 +0800
Subject: [PATCH 1/2] platform: arm64: huawei-gaokun-ec: introduce EC enable
 pin

It seems that there is an enable/reset pin, level high to enable,
low to disable. Use it to help with lid and suspend handling.

Signed-off-by: Pengyu Luo <mitltlatltl@gmail.com>
---
 drivers/platform/arm64/huawei-gaokun-ec.c | 36 +++++++++++++++++++++--
 1 file changed, 33 insertions(+), 3 deletions(-)

diff --git a/drivers/platform/arm64/huawei-gaokun-ec.c b/drivers/platform/arm64/huawei-gaokun-ec.c
index a83ddc20b5a3..e584045a4da8 100644
--- a/drivers/platform/arm64/huawei-gaokun-ec.c
+++ b/drivers/platform/arm64/huawei-gaokun-ec.c
@@ -9,6 +9,7 @@
 #include <linux/cleanup.h>
 #include <linux/delay.h>
 #include <linux/device.h>
+#include <linux/gpio/consumer.h>
 #include <linux/hwmon.h>
 #include <linux/hwmon-sysfs.h>
 #include <linux/i2c.h>
@@ -119,6 +120,8 @@ struct gaokun_ec {
 	struct blocking_notifier_head notifier_list;
 	struct device *hwmon_dev;
 	struct input_dev *idev;
+	struct gpio_desc *enable_gpio;
+	bool lid_opened;
 	bool suspended;
 };
 
@@ -630,6 +633,9 @@ static int gaokun_ec_suspend(struct device *dev)
 	if (ret)
 		return ret;
 
+	msleep(100);
+	gpiod_set_value(ec->enable_gpio, 0);
+
 	ec->suspended = true;
 
 	return 0;
@@ -645,14 +651,25 @@ static int gaokun_ec_resume(struct device *dev)
 	if (!ec->suspended)
 		return 0;
 
+	gpiod_set_value(ec->enable_gpio, 1);
+	msleep(100);
+
 	for (i = 0; i < 3; ++i) {
 		ret = gaokun_ec_write(ec, ec_req);
 		if (ret == 0)
 			break;
 
-		msleep(100); /* EC need time to resume */
+		msleep(100); /* I2C bus need time to resume */
 	}
 
+	if (ret)
+		return ret;
+
+	/* Resume may be unstable, so open lid anyways */
+	input_report_switch(ec->idev, SW_LID, 0);
+	input_sync(ec->idev);
+	ec->lid_opened = true;
+
 	ec->suspended = false;
 
 	return 0;
@@ -718,6 +735,10 @@ static irqreturn_t gaokun_ec_irq_handler(int irq, void *data)
 	u8 status, id;
 	int ret;
 
+	/* EC IO here before resume will fail at the first time, so ignore it */
+	if (ec->suspended)
+		return IRQ_HANDLED;
+
 	ret = gaokun_ec_read_byte(ec, ec_req, &id);
 	if (ret)
 		return IRQ_HANDLED;
@@ -729,8 +750,11 @@ static irqreturn_t gaokun_ec_irq_handler(int irq, void *data)
 	case EC_EVENT_LID:
 		gaokun_ec_psy_read_byte(ec, EC_LID_STATE, &status);
 		status &= EC_LID_OPEN;
-		input_report_switch(ec->idev, SW_LID, !status);
-		input_sync(ec->idev);
+		if (ec->lid_opened != !!status) {
+			input_report_switch(ec->idev, SW_LID, !status);
+			input_sync(ec->idev);
+			ec->lid_opened = !!status;
+		}
 		break;
 
 	default:
@@ -758,6 +782,12 @@ static int gaokun_ec_probe(struct i2c_client *client)
 	i2c_set_clientdata(client, ec);
 	BLOCKING_INIT_NOTIFIER_HEAD(&ec->notifier_list);
 
+	ec->enable_gpio = devm_gpiod_get_optional(dev, "enable",
+						  GPIOD_OUT_HIGH);
+	if (IS_ERR(ec->enable_gpio))
+		dev_err_probe(dev, PTR_ERR(ec->enable_gpio),
+			      "Failed to get enable-gpios\n");
+
 	/* Lid switch */
 	ec->idev = devm_input_allocate_device(dev);
 	if (!ec->idev)
-- 
